# 智能实训评价管理系统 - 环境变量示例
# 复制为 .env 并填写实际值；.env 已在 .gitignore 中忽略

# ============ 后端 ============
TES_ENV=dev
TES_DEBUG=true

# 数据库（dev 默认 sqlite，prod 必须 PostgreSQL）
# TES_DB_URL=postgresql+asyncpg://tes:tes@localhost:5432/tes_dev
TES_DB_URL=sqlite+aiosqlite:///./tes_dev.db

# Redis（用于会话/锁/限流）
TES_REDIS_URL=redis://localhost:6379/0

# JWT（≥ 32 字符）
TES_JWT_SECRET=please-change-this-to-32-or-more-character-secret-string
TES_JWT_ALGORITHM=HS256
TES_JWT_ACCESS_TTL_MINUTES=60
TES_JWT_REFRESH_TTL_DAYS=7

# AES-256 主密钥（base64，≥ 32 字符）
TES_LLM_KEY_MASTER=ZGV2LWxsbS1tYXN0ZXIta2V5LWZvci1kZXZlbG9wbWVudC0zMmJ5

# 上传
TES_UPLOAD_ROOT=./data/uploads
TES_MAX_UPLOAD_SIZE_MB=50

# CORS
TES_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
